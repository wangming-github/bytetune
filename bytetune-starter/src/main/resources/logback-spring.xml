<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

<!-- 日志存放路径 -->
<property name="LOG_PATH" value="logs"/>

<!-- 控制台日志 -->
<appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
        <pattern>
            %d{yyyy-MM-dd HH:mm:ss.SSS} %-10thread %-5level %logger{36} %replace(%X){'\[songId=.*?\]|\[batchId=.*?\]|\[job=.*?\]', ''} - %msg%n
        </pattern>
    </encoder>
</appender>

<!-- 文件日志，按日期 + 大小滚动 -->
<appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/bytetune.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <!-- 每天生成一个新文件，同时单个文件最大 10MB -->
        <fileNamePattern>${LOG_PATH}/archived/bytetune.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
        <maxFileSize>10MB</maxFileSize>
        <maxHistory>30</maxHistory> <!-- 保存 30 天的日志 -->
        <totalSizeCap>1GB</totalSizeCap> <!-- 总大小限制 -->
    </rollingPolicy>
    <encoder>
        <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-10thread %-5level %logger{36} %replace(%X){'\[songId=.*?\]|\[batchId=.*?\]|\[job=.*?\]', ''} - %msg%n</pattern>
    </encoder>
</appender>

<!-- Root 日志 -->
<root level="INFO">
    <appender-ref ref="Console"/>
    <appender-ref ref="File"/>
</root>

<!-- 包级别日志 -->
<logger name="com.bytetune" level="DEBUG"/>
<logger name="com.bytetune.mapper" level="INFO"/>
<logger name="org.springframework" level="WARN"/>
<logger name="org.mongodb" level="INFO"/>
<logger name="com.alibaba.druid" level="INFO"/>

<!-- 异常捕获日志（可选） -->
<logger name="ERROR_LOG" level="ERROR" additivity="false">
    <appender-ref ref="File"/>
</logger>

</configuration>